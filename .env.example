# ╔══════════════════════════════════════════════════════════════════╗
# ║  MOLTY ROYALE AI AGENT — RAILWAY VARIABLES                         ║
# ║  Copy these to Railway Dashboard → Variables tab                   ║
# ╚══════════════════════════════════════════════════════════════════╝

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔴 WAJIB DIISI (Required)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Multi-Agent Config: JSON array of agent configs (copy from credentials.json)
AGENTS_JSON=[{"name":"Agent1","owner_eoa":"0x...","molty_royale_wallet":"0x...","account_id":"...","api_key":"mr_live_...","agent_wallet_address":"0x...","agent_wallet_private_key":"0x..."}]

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🟡 OPTIONAL (Can set, has defaults)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Room mode (applies to ALL agents): free / auto / paid
ROOM_MODE=free

# Filter which agents to run (comma-separated, e.g., "MexL,GENZODR")
# If not set, ALL agents in AGENTS_JSON will run
AGENT_NAMES=MexL,GENZODR

# Logging level: DEBUG / INFO / WARNING
LOG_LEVEL=INFO

# Railway Auto-Sync (optional, for credentials persistence)
# Create token at: https://railway.com/account/tokens
RAILWAY_API_TOKEN=

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ⚙️ FIRST-RUN INTAKE (setup.md questions 1-9)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# All default = true/auto, so zero-config deploy works
ADVANCED_MODE=true             # Q1-3: auto-generate Owner EOA + Agent wallet
AUTO_WHITELIST=true            # Q4: auto-check + auto-approve whitelist
AUTO_SC_WALLET=true            # Q6: auto-create MoltyRoyale SC Wallet
ENABLE_MEMORY=true             # Q7: cross-game learning (molty-royale-context.json)
ENABLE_AGENT_TOKEN=false       # Q8: agent token registration (skip dulu)
AUTO_IDENTITY=true             # Q9: auto-register ERC-8004 identity

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🟢 AUTO-GENERATED (JANGAN DIISI — bot akan mengisi otomatis)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# These are filled by the bot after first-run, DO NOT fill manually:
# API_KEY, AGENT_WALLET_ADDRESS, AGENT_PRIVATE_KEY
# OWNER_EOA, OWNER_PRIVATE_KEY

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ❌ DEPRECATED (Sudah tidak dipakai di multi-agent mode)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AGENT_NAME  → Diganti AGENTS_JSON (multi-agent)
