# ╔════════════════════════════════════════════════════════════════════╗
# ║  MOLTY ROYALE AI AGENT — RAILWAY VARIABLES                         ║
# ║  Copy these to Railway Dashboard → Variables tab                   ║
# ╚════════════════════════════════════════════════════════════════════╝

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🔴 MODE 1: MULTI-AGENT (Recommended for Railway)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Step 1: Confirm account status
HAVE_ACCOUNT=yes                # "yes" = already have accounts (use AGENTS_JSON)
                                # "no" = need to create new account (FIRST-RUN INTAKE)

# Step 2: For agents that ALREADY have accounts (HAVE_ACCOUNT=yes)
# Each agent needs: name, owner_eoa, molty_royale_wallet, account_id, api_key, etc.
AGENTS_JSON=[{"name":"MexL","owner_eoa":"0x...","molty_royale_wallet":"0x...","account_id":"...","api_key":"mr_live_...","agent_wallet_address":"0x...","agent_wallet_private_key":"0x...","room_mode":"free"}]

# Optional: Filter which agents to run (comma-separated)
# CRITICAL: Only run PRIMARY agent of each SC wallet!
# If multiple agents share same molty_royale_wallet, ONLY run the PRIMARY one
# Example: If MexL is PRIMARY, only run MexL (not GENZODR, etc.)
AGENT_NAMES=MexL

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🆕 MODE 2: CREATE NEW AGENT (Single-Agent)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Use this to CREATE a NEW agent (triggers FIRST-RUN INTAKE)
# Comment out AGENTS_JSON above if using this mode!
HAVE_ACCOUNT=no                # NO - need to create new account
AGENT_NAME=NewAgent              # Name for the new agent (max 50 chars)
ROOM_MODE=free                      # Room mode for new agent: free / auto / paid

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ⚙️ FIRST-RUN INTAKE (setup.md questions 1-9)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# These run ONLY in MODE 2 (AGENT_NAME) or if AGENTS_JSON has empty api_key
# All default = true/auto, so zero-config deploy works
ADVANCED_MODE=true             # Q1-3: auto-generate Owner EOA + Agent wallet
AUTO_WHITELIST=true            # Q4: auto-check + auto-approve whitelist
AUTO_SC_WALLET=true            # Q6: auto-create MoltyRoyale SC Wallet
ENABLE_MEMORY=true             # Q7: cross-game learning (molty-royale-context.json)
ENABLE_AGENT_TOKEN=false       # Q8: agent token registration (skip dulu)
AUTO_IDENTITY=true             # Q9: auto-register ERC-8004 identity

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🟡 OPTIONAL (Can set, has defaults)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
LOG_LEVEL=INFO                 # DEBUG / INFO / WARNING

# Railway Auto-Sync (optional, for credentials persistence)
# Create token at: https://railway.com/account/tokens
RAILWAY_API_TOKEN=             # Optional: auto-save credentials to Railway Variables

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# 🟢 AUTO-GENERATED (DO NOT FILL — bot will fill automatically)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# These are filled by the bot after first-run, DO NOT fill manually:
# API_KEY, AGENT_WALLET_ADDRESS, AGENT_PRIVATE_KEY
# OWNER_EOA, OWNER_PRIVATE_KEY

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ❌ DEPRECATED (Already not used in multi-agent mode)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ROOM_MODE (global) → Diganti room_mode per-agent di AGENTS_JSON
